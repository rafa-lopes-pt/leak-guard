{
  "name": "leakguard",
  "version": "0.0.0-beta.0",
  "description": "GitHub security hardening toolkit -- pre-commit hooks and CI for secret scanning, keyword blocking, and file type enforcement",
  "type": "module",
  "bin": {
    "leakguard": "bin/leakguard.js"
  },
  "files": [
    "bin/",
    "scripts/",
    ".gitleaks.toml",
    ".security-filetypes.default",
    "workflows/",
    "security-keywords.txt.example",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "leakguard": {
    "gitleaksVersion": "8.21.2"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "encrypt-keywords": "node scripts/encrypt-keywords.js",
    "scan-history": "node scripts/scan-history.js",
    "test": "node --test 'tests/**/*.test.js'",
    "lint": "eslint ."
  },
  "keywords": [
    "security",
    "github",
    "pre-commit",
    "gitleaks",
    "secret-scanning",
    "git-hooks"
  ],
  "author": "rafa-lopes-pt",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafa-lopes-pt/leak-guard.git"
  },
  "homepage": "https://github.com/rafa-lopes-pt/leak-guard#readme",
  "bugs": {
    "url": "https://github.com/rafa-lopes-pt/leak-guard/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0"
  }
}
